# Akowe — optional API keys for cloud transcription/summarization
# Works fully offline with pasted transcripts + extractive summarization

PORT=8791
AKOWE_DATABASE_PATH=./data/akowe.json

# Optional — enables Whisper transcription + GPT summarization
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1
OPENAI_CHAT_MODEL=gpt-4o-mini
