{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "noEmit": true,
    "paths": {
      "@sportverse/content-gen": ["../../packages/content-gen/src/index.ts"],
      "@sportverse/sports-db": ["../../packages/sports-db/src/index.ts"],
      "@sportverse/quiz-engine": ["../../packages/quiz-engine/src/index.ts"],
      "@sportverse/sim-core": ["../../packages/sim-core/src/index.ts"],
      "@sportverse/platform": ["../../packages/platform/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
