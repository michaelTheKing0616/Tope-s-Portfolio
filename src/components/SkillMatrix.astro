---
interface Capability {
  domain: string;
  blurb: string;
  stack: string[];
}

const capabilities: Capability[] = [
  {
    domain: "Web",
    blurb: "Full-stack apps and award-minded front-ends, from data layer to motion.",
    stack: ["TypeScript", "React / Next.js", "Astro", "Node.js", "PostgreSQL", "Tailwind"],
  },
  {
    domain: "Mobile",
    blurb: "Cross-platform products that ship to Android and iOS from one codebase.",
    stack: ["Flutter", "Dart", "REST APIs", "Offline-first"],
  },
  {
    domain: "AI",
    blurb: "Agentic systems, RAG and LLM features built as reliable services, not demos.",
    stack: ["Python", "LLM Integration", "Tool-calling", "RAG / Vector DB", "Evals", "ElevenLabs"],
  },
  {
    domain: "Desktop",
    blurb: "Native, privacy-first desktop apps with small, fast binaries.",
    stack: ["Tauri", "Rust", "Electron", "Local LLM"],
  },
  {
    domain: "Games",
    blurb: "Game loops, state machines and real adversarial-search AI, made playable.",
    stack: ["Canvas / WebGL", "Minimax", "Web Audio", "TypeScript"],
  },
  {
    domain: "Systems",
    blurb: "Libraries, CI/CD and the engineering rigor that holds production together.",
    stack: ["Git / GitHub", "GitHub Actions", "Testing", "SDLC / Agile", "Netlify"],
  },
];
---

<div class="matrix">
  {
    capabilities.map((cap, i) => (
      <article class="matrix__cell" data-reveal data-reveal-delay={(i % 3) * 0.06}>
        <header class="matrix__head">
          <span class="matrix__index">{String(i + 1).padStart(2, "0")}</span>
          <h3 class="matrix__domain">{cap.domain}</h3>
        </header>
        <p class="matrix__blurb">{cap.blurb}</p>
        <ul class="matrix__stack">
          {cap.stack.map((s) => (
            <li>{s}</li>
          ))}
        </ul>
      </article>
    ))
  }
</div>

<style>
  .matrix {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(184, 149, 74, 0.16);
    border: 1px solid rgba(184, 149, 74, 0.16);
  }
  .matrix__cell {
    background: var(--ink);
    padding: 34px 30px;
    transition: background 0.3s ease;
  }
  .matrix__cell:hover {
    background: var(--ink-soft, #1a1814);
  }
  .matrix__head {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 14px;
  }
  .matrix__index {
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--gold);
  }
  .matrix__domain {
    font-family: "Cormorant Garamond", serif;
    font-size: 30px;
    font-weight: 600;
    color: var(--gold-light);
    line-height: 1;
  }
  .matrix__blurb {
    font-size: 13px;
    line-height: 1.6;
    color: #9a9488;
    margin-bottom: 18px;
    min-height: 62px;
  }
  .matrix__stack {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .matrix__stack li {
    font-size: 10px;
    letter-spacing: 0.03em;
    color: #b0aa9e;
    padding: 4px 9px;
    border: 1px solid rgba(184, 149, 74, 0.2);
    border-radius: 999px;
  }

  @media (max-width: 900px) {
    .matrix {
      grid-template-columns: repeat(2, 1fr);
    }
    .matrix__blurb {
      min-height: 0;
    }
  }
  @media (max-width: 560px) {
    .matrix {
      grid-template-columns: 1fr;
    }
  }
</style>
