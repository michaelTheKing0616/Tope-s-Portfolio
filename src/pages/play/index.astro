---
import Base from "../../layouts/Base.astro";

const games = [
  {
    title: "SPORTVERSE",
    tag: "Flagship",
    blurb:
      "Football IQ, Goalkeeper Instinct, and five Sports IQ quiz modes — 1000+ rounds each. One XP profile, daily challenges, leaderboards.",
    href: "/play/sportverse/",
    cta: "Play SPORTVERSE",
    featured: true,
  },
  {
    title: "Demos hub",
    tag: "Interactive",
    blurb: "Embedded previews and case-study demos from the portfolio.",
    href: "/demos",
    cta: "View demos",
  },
];
---

<Base title="Play — Temitope Olaitan" description="Play SPORTVERSE and interactive demos from one portfolio site.">
  <section class="mx-auto max-w-4xl px-6 py-16">
    <p class="text-sm uppercase tracking-widest text-emerald-400/90">Interactive</p>
    <h1 class="mt-2 font-display text-4xl font-bold tracking-tight text-white md:text-5xl">Play</h1>
    <p class="mt-4 max-w-2xl text-lg text-slate-300">
      All games ship inside this portfolio — one deploy, one URL. No separate app installs required.
    </p>

    <div class="mt-12 grid gap-6">
      {
        games.map((game) => (
          <article
            class:list={[
              "rounded-2xl border p-8 transition hover:border-emerald-500/40",
              game.featured ? "border-emerald-500/30 bg-emerald-950/20" : "border-white/10 bg-white/5",
            ]}
          >
            <span class="text-xs font-medium uppercase tracking-wider text-emerald-400">{game.tag}</span>
            <h2 class="mt-2 text-2xl font-semibold text-white">{game.title}</h2>
            <p class="mt-3 text-slate-300">{game.blurb}</p>
            <a
              href={game.href}
              class="mt-6 inline-flex items-center rounded-lg bg-emerald-500 px-5 py-2.5 text-sm font-semibold text-slate-950 hover:bg-emerald-400"
            >
              {game.cta} →
            </a>
          </article>
        ))
      }
    </div>

    <div class="mt-12 rounded-xl border border-white/10 bg-white/5 p-6 text-sm text-slate-400">
      <p>
        <strong class="text-slate-200">Local dev:</strong> run <code class="text-emerald-300">npm run build:games</code> then
        <code class="text-emerald-300">npm run dev</code> — open <a href="/play/sportverse/" class="text-emerald-400 underline">/play/sportverse/</a>
      </p>
      <p class="mt-2">
        <strong class="text-slate-200">Deploy:</strong> see <code class="text-emerald-300">UNIFIED_PLAY_DEPLOY.md</code> for Netlify/Vercel setup.
      </p>
    </div>
  </section>
</Base>
