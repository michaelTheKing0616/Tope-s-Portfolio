---
import Base from "../layouts/Base.astro";
import { site } from "../data/site";
import {
  profile,
  experience,
  education,
  skillGroups,
} from "../data/resume";

const contactRows = [
  { label: "Email", value: site.email, href: `mailto:${site.email}` },
  { label: "Phone", value: site.phone, href: `tel:${site.phoneRaw}` },
  { label: "WhatsApp", value: site.phone, href: `https://wa.me/${site.phoneRaw.replace("+", "")}` },
  { label: "X / Twitter", value: "@TemitopeOlait10", href: "https://x.com/TemitopeOlait10" },
  { label: "Instagram", value: "@topemichaelolaitan", href: "https://www.instagram.com/topemichaelolaitan" },
  { label: "Location", value: site.location },
];
---

<Base
  title="Resume — Temitope Olaitan"
  description="The resume of Temitope Olaitan — Software Engineer & AI Builder, First Class B.Tech in Computer Science."
>
  <div class="dl-bar">
    <div class="shell-wide dl-bar__inner">
      <span class="dl-bar__label">Curriculum Vitae</span>
      <div class="dl-bar__actions">
        <button class="dl-btn" type="button" data-print>Print / Save as PDF</button>
        <a class="dl-btn dl-btn--gold" href="/contact">Get in touch</a>
      </div>
    </div>
  </div>

  <section class="resume shell-wide">
    <aside class="r-left" data-reveal>
      <div class="r-photo">
        <picture>
          <source srcset="/images/portrait-sm.avif" type="image/avif" />
          <source srcset="/images/portrait-sm.webp" type="image/webp" />
          <img
            src="/images/portrait.jpg"
            alt="Portrait of Temitope Olaitan"
            width="420"
            height="420"
            loading="eager"
            decoding="async"
          />
        </picture>
      </div>
      <h1 class="r-name">{site.name}</h1>
      <p class="r-role">{site.role}</p>

      <div class="r-block">
        <span class="r-label">Contact</span>
        <ul class="r-contact">
          {
            contactRows.map((c) => (
              <li>
                <span class="r-contact__k">{c.label}</span>
                {c.href ? (
                  <a href={c.href} class="r-contact__v link-underline" target="_blank" rel="noopener">
                    {c.value}
                  </a>
                ) : (
                  <span class="r-contact__v">{c.value}</span>
                )}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="r-block">
        <span class="r-label">Skills</span>
        {
          skillGroups.map((g) => (
            <div class="r-skillgroup">
              <span class="r-skillgroup__label">{g.label}</span>
              <div class="r-tags">
                {g.skills.map((s) => (
                  <span class:list={["r-tag", { "r-tag--gold": s.emphasis }]}>{s.name}</span>
                ))}
              </div>
            </div>
          ))
        }
      </div>

      <div class="r-block">
        <span class="r-label">Education</span>
        {
          education.map((e) => (
            <div class="r-edu">
              <p class="r-edu__degree">{e.degree}</p>
              <p class="r-edu__honour">{e.honour}</p>
              <p class="r-edu__school">{e.school}</p>
              <p class="r-edu__year">{e.year}</p>
            </div>
          ))
        }
      </div>
    </aside>

    <main class="r-right">
      <section class="r-section" data-reveal>
        <div class="section-label">Profile</div>
        <p class="r-lead">{profile}</p>
      </section>

      <section class="r-section" data-reveal>
        <div class="section-label">Experience</div>
        {
          experience.map((x) => (
            <div class="exp">
              <div class="exp__head">
                <div>
                  <h2 class="exp__role">{x.role}</h2>
                  <p class="exp__org">{x.org}</p>
                </div>
                <span class="exp__date">{x.date}</span>
              </div>
              <ul class="exp__bullets">
                {x.bullets.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </section>
    </main>
  </section>
</Base>

<style>
  .dl-bar {
    background: var(--ink);
    border-bottom: 1px solid rgba(184, 149, 74, 0.2);
    padding-top: 72px;
  }
  .dl-bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-top: 20px;
    padding-bottom: 20px;
  }
  .dl-bar__label {
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .dl-bar__actions {
    display: flex;
    gap: 10px;
  }
  .dl-btn {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold-light);
    border: 1px solid rgba(184, 149, 74, 0.4);
    background: transparent;
    padding: 11px 20px;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .dl-btn:hover {
    border-color: var(--gold);
    color: var(--gold);
  }
  .dl-btn--gold {
    background: var(--gold);
    color: var(--ink);
    border-color: var(--gold);
  }
  .dl-btn--gold:hover {
    background: var(--gold-light);
    color: var(--ink);
  }

  .resume {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 0;
    padding-top: clamp(40px, 6vw, 64px);
    padding-bottom: clamp(72px, 11vw, 130px);
  }
  .r-left {
    background: var(--ink);
    color: var(--gold-light);
    padding: 44px 36px;
  }
  .r-photo {
    width: 130px;
    margin-bottom: 24px;
  }
  .r-photo img {
    width: 100%;
    border-radius: 50%;
    border: 1px solid rgba(184, 149, 74, 0.4);
  }
  .r-name {
    font-family: "Cormorant Garamond", serif;
    font-size: 34px;
    font-weight: 600;
    line-height: 1;
    color: var(--gold-light);
  }
  .r-role {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
    margin: 10px 0 30px;
  }
  .r-block {
    border-top: 1px solid rgba(184, 149, 74, 0.18);
    padding-top: 20px;
    margin-top: 28px;
  }
  .r-label {
    display: block;
    font-size: 9px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
  }
  .r-contact {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .r-contact li {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .r-contact__k {
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #6f6a60;
  }
  .r-contact__v {
    font-size: 13px;
    color: #c8c2b6;
    word-break: break-word;
  }

  .r-skillgroup {
    margin-bottom: 18px;
  }
  .r-skillgroup__label {
    display: block;
    font-size: 10px;
    letter-spacing: 0.08em;
    color: #8a8478;
    margin-bottom: 8px;
  }
  .r-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .r-tag {
    font-size: 10px;
    color: #b0aa9e;
    padding: 4px 9px;
    border: 1px solid rgba(184, 149, 74, 0.2);
    border-radius: 999px;
  }
  .r-tag--gold {
    color: var(--ink);
    background: var(--gold);
    border-color: var(--gold);
  }

  .r-edu {
    margin-bottom: 18px;
  }
  .r-edu__degree {
    font-size: 13.5px;
    color: var(--gold-light);
    line-height: 1.4;
  }
  .r-edu__honour {
    font-size: 11px;
    color: var(--gold);
    margin: 2px 0;
  }
  .r-edu__school {
    font-size: 12px;
    color: #9a9488;
  }
  .r-edu__year {
    font-size: 11px;
    color: #6f6a60;
  }

  .r-right {
    background: var(--smoke);
    padding: 44px 0 44px 52px;
  }
  .r-section {
    margin-bottom: 48px;
  }
  .r-lead {
    margin-top: 22px;
    font-size: 16px;
    line-height: 1.8;
    color: #3a3a37;
    max-width: 64ch;
  }
  .exp {
    margin-top: 26px;
    padding-bottom: 26px;
    border-bottom: 1px solid var(--rule);
  }
  .exp:last-child {
    border-bottom: 0;
  }
  .exp__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 12px;
  }
  .exp__role {
    font-family: "Cormorant Garamond", serif;
    font-size: 24px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.1;
  }
  .exp__org {
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    margin-top: 4px;
  }
  .exp__date {
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--mid);
    white-space: nowrap;
  }
  .exp__bullets {
    padding-left: 18px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .exp__bullets li {
    font-size: 14px;
    line-height: 1.65;
    color: #4a4a46;
  }
  .exp__bullets li::marker {
    color: var(--gold);
  }

  @media (max-width: 860px) {
    .resume {
      grid-template-columns: 1fr;
    }
    .r-right {
      padding: 36px 0 0;
    }
  }

  @media print {
    .dl-bar,
    :global(.site-nav),
    :global(.foot),
    :global(.hero__cue) {
      display: none !important;
    }
    .resume {
      grid-template-columns: 300px 1fr;
      padding: 0;
    }
    .r-right {
      padding: 24px 0 0 32px;
    }
    :global(body) {
      background: #fff;
    }
  }
</style>

<script>
  document
    .querySelector<HTMLButtonElement>("[data-print]")
    ?.addEventListener("click", () => window.print());
</script>
