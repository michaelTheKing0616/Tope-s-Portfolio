---
import Base from "../layouts/Base.astro";
import AyoGame from "../components/demos/AyoGame.astro";
import SabiAgentTrace from "../components/demos/SabiAgentTrace.astro";
import LingafriqCard from "../components/demos/LingafriqCard.astro";
import SportverseDemo from "../components/demos/SportverseDemo.astro";

const demos = [
  { id: "sportverse", n: "01", domain: "Games + Platform", title: "SPORTVERSE — Football IQ", slug: "sportverse", blurb: "One tactical decision, four seconds, instant coaching. A slice of the full sports gaming platform." },
  { id: "ayo", n: "02", domain: "Games + AI", title: "Ayo Master", slug: "ayo-master", blurb: "A real minimax + alpha-beta opponent inside a centuries-old African board game. Play it — it actually thinks ahead." },
  { id: "sabi", n: "03", domain: "Agentic AI", title: "Sabi — agent trace", slug: "sabi", blurb: "Watch the planner → tool-call → critic → answer loop the production system is built around. Deterministic, no API key." },
  { id: "lingafriq", n: "04", domain: "Mobile + AI", title: "LingAfriq micro-lesson", slug: "lingafriq", blurb: "A taste of the real product: flip-to-reveal phrases in Yoruba, Igbo and Hausa, with best-effort device audio." },
];
---

<Base
  title="Live Demos — Temitope Olaitan"
  description="Interactive, in-browser demos: SPORTVERSE tactical football, minimax board-game AI, agentic-AI trace, and a language micro-lesson."
>
  <section class="page-head">
    <div class="shell-wide">
      <div class="section-label" data-reveal>Live Demos</div>
      <h1 class="page-head__title" data-reveal data-reveal-delay="0.06">
        Don't take my word for it — <em>play</em> with it.
      </h1>
      <p class="page-head__lead" data-reveal data-reveal-delay="0.12">
        Four working artifacts running entirely in your browser: a sports platform slice,
        a game with genuine adversarial-search AI, an agentic workflow visualisation, and
        a mobile learning interaction.
      </p>

      <nav class="demo-jump" data-reveal data-reveal-delay="0.16" aria-label="Jump to a demo">
        {demos.map((d) => <a href={`#${d.id}`} class="demo-jump__link">{d.title}</a>)}
      </nav>
    </div>
  </section>

  {
    demos.map((d, idx) => (
      <section id={d.id} class:list={["demo", { "demo--ink": idx % 2 === 1 }]}>
        <div class="shell-wide demo__inner">
          <header class="demo__head" data-reveal>
            <span class="demo__n">{d.n}</span>
            <div>
              <span class="demo__domain">{d.domain}</span>
              <h2 class="demo__title">{d.title}</h2>
              <p class="demo__blurb">{d.blurb}</p>
              <a href={`/work/${d.slug}`} class="demo__link link-underline">Read the case study &rarr;</a>
            </div>
          </header>

          <div class="demo__stage" data-reveal data-reveal-delay="0.08">
            {d.id === "sportverse" && <SportverseDemo />}
            {d.id === "ayo" && <AyoGame />}
            {d.id === "sabi" && <SabiAgentTrace />}
            {d.id === "lingafriq" && <LingafriqCard />}
          </div>
        </div>
      </section>
    ))
  }
</Base>

<style>
  .page-head {
    padding: clamp(120px, 16vw, 180px) 0 clamp(40px, 6vw, 64px);
    background: linear-gradient(180deg, #efede8, var(--smoke));
  }
  .page-head__title {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(2.6rem, 7vw, 5rem);
    font-weight: 300;
    line-height: 1.02;
    color: var(--ink);
    margin: 22px 0 22px;
  }
  .page-head__title em {
    font-style: italic;
    color: var(--gold);
  }
  .page-head__lead {
    max-width: 64ch;
    font-size: 15.5px;
    line-height: 1.75;
    color: var(--mid);
  }
  .demo-jump {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    margin-top: 30px;
  }
  .demo-jump__link {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .demo {
    padding: clamp(64px, 10vw, 120px) 0;
    background: var(--smoke);
    scroll-margin-top: 80px;
  }
  .demo--ink {
    background: var(--ink);
  }
  .demo__inner {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 56px;
    align-items: center;
  }
  .demo__head {
    display: flex;
    gap: 18px;
  }
  .demo__n {
    font-family: "Cormorant Garamond", serif;
    font-size: 40px;
    line-height: 1;
    color: rgba(184, 149, 74, 0.4);
  }
  .demo__domain {
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .demo__title {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    line-height: 1.05;
    margin: 8px 0 14px;
  }
  .demo:not(.demo--ink) .demo__title {
    color: var(--ink);
  }
  .demo--ink .demo__title {
    color: var(--gold-light);
  }
  .demo__blurb {
    font-size: 15px;
    line-height: 1.7;
    max-width: 46ch;
    margin-bottom: 16px;
  }
  .demo:not(.demo--ink) .demo__blurb {
    color: var(--mid);
  }
  .demo--ink .demo__blurb {
    color: #9a9488;
  }
  .demo__link {
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--gold);
  }

  @media (max-width: 900px) {
    .demo__inner {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }
</style>
