---
import Base from "../../layouts/Base.astro";
---

<Base title="Stadium Dark — Showcase" description="Immersive stadium-night sports UI demo.">
  <div class="relative min-h-screen overflow-hidden bg-[#0a0e0c] text-white">
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_50%_120%,rgba(16,185,129,0.18),transparent_55%),linear-gradient(180deg,#0a0e0c_0%,#050807_100%)]"></div>
    <div class="pointer-events-none absolute inset-0 opacity-[0.07]" style="background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E');"></div>
    <nav class="relative mx-auto flex max-w-6xl items-center justify-between px-6 py-6">
      <span class="font-mono text-sm tracking-[0.25em] text-emerald-400/90">PITCH//NIGHT</span>
      <a href="/showcase" class="text-sm text-stone-500 hover:text-white">← Showcase</a>
    </nav>
    <main class="relative mx-auto max-w-6xl px-6 pb-24 pt-10">
      <div class="grid gap-10 lg:grid-cols-2 lg:items-end">
        <div>
          <p class="font-mono text-xs uppercase tracking-[0.35em] text-emerald-500/80">Live · MD 38</p>
          <h1 class="mt-4 font-serif text-5xl leading-[0.95] md:text-7xl">Under the<br/>floodlights</h1>
          <p class="mt-6 max-w-md text-stone-400">Stadium-dark UI — scoreboard typography, pitch-green accents, grain texture. Built for sports products that feel broadcast-ready.</p>
        </div>
        <div class="rounded-2xl border border-emerald-900/40 bg-black/40 p-8 backdrop-blur-sm">
          <div class="flex items-end justify-between border-b border-white/10 pb-4">
            <div><p class="text-xs text-stone-500">HOME</p><p class="text-4xl font-bold tabular-nums">3</p></div>
            <p class="font-mono text-xs text-stone-500">90+4</p>
            <div class="text-right"><p class="text-xs text-stone-500">AWAY</p><p class="text-4xl font-bold tabular-nums">1</p></div>
          </div>
          <ul class="mt-4 space-y-2 font-mono text-xs text-stone-400">
            <li>12' · GOAL · Home · #10</li>
            <li>34' · GOAL · Away · #9</li>
            <li>78' · GOAL · Home · #7</li>
          </ul>
        </div>
      </div>
    </main>
  </div>
</Base>
