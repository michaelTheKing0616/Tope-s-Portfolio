---
import Base from "../../layouts/Base.astro";
---

<Base title="Editorial Brutalism — Showcase" description="Post-modern editorial web design demo.">
  <div class="min-h-screen bg-[#f4f0e8] text-[#111]">
    <header class="border-b-4 border-black px-6 py-8 md:px-12">
      <a href="/showcase" class="text-xs font-bold uppercase tracking-widest">← Showcase</a>
      <h1 class="mt-8 max-w-4xl font-serif text-6xl font-black leading-[0.9] md:text-8xl">BRUTAL<br/>CLARITY</h1>
    </header>
    <main class="grid md:grid-cols-12">
      <aside class="border-b-4 border-black p-8 md:col-span-4 md:border-b-0 md:border-r-4">
        <p class="text-sm leading-relaxed">Raw grids. No decoration without purpose. Typography carries the entire layout.</p>
      </aside>
      <section class="p-8 md:col-span-8 md:p-12">
        <p class="text-xs uppercase tracking-[0.4em]">Case study</p>
        <h2 class="mt-4 text-3xl font-bold">When content is king, chrome gets out of the way.</h2>
        <button class="mt-10 border-4 border-black bg-[#ff5c00] px-8 py-4 text-sm font-bold uppercase tracking-wider text-black">Start project</button>
      </section>
    </main>
  </div>
</Base>
