---
import Base from "../../layouts/Base.astro";
---

<Base title="Fintech Precision — Showcase" description="Trust-first fintech landing demo.">
  <div class="min-h-screen bg-slate-50 text-slate-900">
    <nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-6">
      <span class="font-semibold tracking-tight">Ledger<span class="text-blue-600">Flow</span></span>
      <a href="/showcase" class="text-sm text-slate-500 hover:text-slate-900">← Showcase</a>
    </nav>
    <main class="mx-auto max-w-5xl px-6 pb-24 pt-12">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-blue-600">Trusted by 2,400 teams</p>
          <h1 class="mt-4 text-4xl font-semibold tracking-tight md:text-5xl">Finance ops with surgical precision.</h1>
          <p class="mt-4 text-slate-600">Monospace numbers, tight grids, and restrained blue/green trust signals — conversion without noise.</p>
          <button class="mt-8 rounded-lg bg-slate-900 px-6 py-3 text-sm font-medium text-white">Start reconciliation</button>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
          <div class="flex items-center justify-between text-xs text-slate-500">
            <span>Monthly volume</span>
            <span class="rounded-full bg-emerald-50 px-2 py-0.5 text-emerald-700">+12.4%</span>
          </div>
          <p class="mt-2 font-mono text-4xl font-semibold tabular-nums tracking-tight">₦48,291,004.00</p>
          <div class="mt-6 grid grid-cols-3 gap-4 border-t border-slate-100 pt-4 text-center">
            <div><p class="font-mono text-lg font-semibold">99.98%</p><p class="text-xs text-slate-500">Uptime</p></div>
            <div><p class="font-mono text-lg font-semibold">1.2s</p><p class="text-xs text-slate-500">Settlement</p></div>
            <div><p class="font-mono text-lg font-semibold">SOC2</p><p class="text-xs text-slate-500">Certified</p></div>
          </div>
        </div>
      </div>
    </main>
  </div>
</Base>
