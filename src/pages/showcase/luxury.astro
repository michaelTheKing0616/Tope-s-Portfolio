---
import Base from "../../layouts/Base.astro";
---

<Base title="Quiet Luxury — Showcase" description="Premium minimal web design demo.">
  <div class="min-h-screen bg-[#0a0a0a] text-[#e8e4dc]">
    <header class="mx-auto flex max-w-4xl items-center justify-between px-8 py-10">
      <span class="font-serif text-lg tracking-[0.2em]">ATELIER</span>
      <a href="/showcase" class="text-xs uppercase tracking-widest text-[#888]">Showcase</a>
    </header>
    <main class="mx-auto max-w-4xl px-8 pb-32 pt-20 text-center">
      <p class="text-xs uppercase tracking-[0.35em] text-[#888]">Private client work</p>
      <h1 class="mt-8 font-serif text-5xl font-light leading-tight md:text-7xl">Less, but<br/>exceptional.</h1>
      <p class="mx-auto mt-8 max-w-md text-sm leading-relaxed text-[#999]">Whitespace as luxury. Serif rhythm. Motion only where it earns its place.</p>
      <div class="mx-auto mt-16 h-px w-24 bg-[#333]"></div>
    </main>
  </div>
</Base>
